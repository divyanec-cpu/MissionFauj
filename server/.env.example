# Copy this file to .env and fill in real values.

# Postgres connection string. For local dev, point at a local Postgres instance;
# in production (Render) this is provided by the managed Postgres add-on.
DATABASE_URL="postgresql://missionfauj:missionfauj_dev@localhost:5432/missionfauj"

# JWT signing secret for the short-lived phone/age verification tokens issued
# during the login sequence.
JWT_SECRET="change-me-to-a-long-random-string"

# MSG91 (https://msg91.com) — used to send/verify real SMS OTPs via the OTP
# Widget product (dashboard tile literally called "OTP", showing a Widget ID —
# not the older "authkey + template_id" OTP API).
MSG91_WIDGET_ID=""
MSG91_TOKEN_AUTH=""

PORT=4000
